# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจาก Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role key (Settings > API > "service_role secret") — ใช้เฉพาะฝั่งเซิร์ฟเวอร์
# สำหรับสร้างบัญชีพนักงาน/รีเซ็ตรหัสผ่านจากหน้า "จัดการพนักงาน"
# ห้ามใส่ NEXT_PUBLIC_ นำหน้า และห้าม commit ค่าจริงขึ้น git เด็ดขาด
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
